rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isTeamMember(teamId) {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/teams/$(teamId)/members/$(request.auth.uid));
    }

    // Users can only access their own files
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Team master schedules - restricted to members of the team
    match /teams/{teamId}/masterSchedules/{allPaths=**} {
      allow read, write: if isTeamMember(teamId);
    }

    // Team route map images
    match /teams/{teamId}/routeMaps/{allPaths=**} {
      allow read, write: if isTeamMember(teamId);
    }

    // Team transit app data (aggregated JSON)
    match /teams/{teamId}/transitAppData/{allPaths=**} {
      allow read, write: if isTeamMember(teamId);
    }

    // Team performance data (STREETS summaries)
    match /teams/{teamId}/performanceData/{allPaths=**} {
      allow read, write: if isTeamMember(teamId);
    }

    // Team OD matrix data (origin-destination summaries)
    match /teams/{teamId}/odMatrixData/{allPaths=**} {
      allow read, write: if isTeamMember(teamId);
    }
  }
}
