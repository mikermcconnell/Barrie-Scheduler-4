# Copy this file to .env.local for local overrides.
# Do not commit real secrets.

GEMINI_API_KEY=REPLACE_WITH_LOCAL_GEMINI_API_KEY
OPTIMIZE_RATE_LIMIT_PER_HOUR=20
OPTIMIZE_MULTI_PHASE=1
VITE_OPTIMIZE_TIMEOUT_MS=300000
VITE_OPTIMIZE_MAX_RETRIES=0

# Optional: force a single backend endpoint instead of the local /api proxy fallback
# VITE_OPTIMIZE_API_URL=https://optimizeschedule-ieeja7khcq-uc.a.run.app

# Optional: required for map features that call Mapbox directly
# VITE_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Optional: local-only dev login for Playwright / UI review.
# Use a real Firebase test account that already has access to the team you want to inspect.
# VITE_DEV_AUTH_EMAIL=dev-admin@example.com
# VITE_DEV_AUTH_PASSWORD=replace_with_local_password
# VITE_DEV_AUTH_LABEL=Dev Admin Access
# VITE_DEV_AUTH_AUTO_LOGIN=0
# Optional: if the dev user has no team yet, auto-join this invite code on localhost.
# VITE_DEV_AUTH_TEAM_INVITE_CODE=ABC123
