{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit",
            "timeout": 60,
            "statusMessage": "Type-checking after edit..."
          },
          {
            "type": "command",
            "command": "node .claude/hooks/run-related-tests.js",
            "timeout": 50,
            "statusMessage": "Running related tests..."
          }
        ]
      }
    ]
  }
}
